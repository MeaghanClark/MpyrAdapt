#!/bin/bash

# align_to_genome.sbatch
# This script uses bwa mem to aligned trimmed and QC-checked reads to a reference genome. 
# resulting sam files are converted to bam, then indexed, sorted, duplicates are removed, and read pair overlap trimmed
# Last updated 03/02/2026 by MI Clark, originally written by MI Clark and R Toczydlowski based on scripts by B Reid and T Linderoth

#--------------- EXECUTABLE ---------------

# This script aligns pairs of forward and reverse sequence files listed in a text file to the given reference and trims overlap between read pairs
# Input: Reference genome path, forward and reverse reads from wrapper-align_to_genome.sh 
#
# Output: ${SAMPLE_NAME}.trim.bam file, forward and reverse reads aligned to reference genome and trimmed

# load modules 
module load bwa-mem2/2.2.1
module load samtools/1.21
module list 

# required imports from wrapper: 
#	ARRAY_KEY
# 	REFERENCE
# 	CPUS
#	OUTDIR
#	SCRATCHNODE

line=$(sed -n "${SLURM_ARRAY_TASK_ID}p" "$ARRAY_KEY")

IFS=$'\t' read -r SAMPLE_NAME FORWARDREAD REVERSEREAD MERGEDREAD <<< "$line"

#IFS=$'\t' read -r SAMPLE_NAME  <<< "$line"
#FORWARDREAD=${INDIR}/unmerged/${SAMPLE_NAME}_r1.fq.gz
#REVERSEREAD=${INDIR}/unmerged/${SAMPLE_NAME}_r2.fq.gz
#MERGEDREAD=${INDIR}/merged/${SAMPLE_NAME}_r1.fq.gz

# BASE=$(basename "$FORWARDREAD")
# SAMPLE_NAME=$(echo "${BASE}" | cut -d "_" -f 1,2 | cut -d "." -f 2)

# text for troubleshooting
echo using $REFERENCE 
echo trying to locate files $FORWARDREAD and $REVERSEREAD and $MERGEDREAD
echo I will put the output in ${SCRATCHNODE}/${SAMPLE_NAME}.aln-pe.sam 

# generate read group information 

# Define DATASTRING based on SAMPLE_NAME content
if [[ "$SAMPLE_NAME" == *MOL* ]]; then
  DATASTRING="Whole genome sequence from Macrocystis pyrifera from Molano et al., PRJNA661280"
elif [[ "$SAMPLE_NAME" == *ALB* ]]; then
  DATASTRING="Whole genome sequence from Macrocystis pyrifera generated by Alberto lab 2025"
elif [[ "$SAMPLE_NAME" == *GON* ]]; then
  DATASTRING="Whole genome sequence from Macrocystis pyrifera from Gonzalez et al., PRJNA938791"
fi

echo I am using data string $DATASTRING for $SAMPLE_NAME

prevrg='N'
readgroup=''
nmatch=0
lstart=-3

# need to check multiple headers to make sure sample barcodes converge (i.e. no sequencing error)
while [ $nmatch -lt 10 ]
do
	lstart=$((lstart + 4))
	lend=$((lstart + 1))
	readheader=$(zcat "$FORWARDREAD" | sed -n "${lstart}p;${lend}q" | sed 's/ [[:digit:]]//')
	readinfo=($(echo "$readheader" | perl -e 'chomp($read = <>); @arr = split(/:/,$read); print "@arr[2,3,$#arr]";'))
	barcode=$(sed 's/+/-/' <<< "${readinfo[2]}")
	readgroup="@RG\tID:${readinfo[0]}.${readinfo[1]}\tBC:${barcode}\tDS:${DATADS}\tLB:${samplib}\tPL:ILLUMINA\tPU:${readinfo[0]}.${readinfo[1]}.${barcode}\tSM:${SAMPLE_NAME}"

	if [ "$readgroup" = "$prevrg" ] && ! [[ "$barcode" =~ 'N' ]]; then ((nmatch++)); fi
	prevrg="$readgroup"
done

echo using $readgroup

###
#run bwa 
# align paired reads and convert to bam
CMD="bwa-mem2 mem -t $CPUS -R '$readgroup' $REFERENCE $FORWARDREAD $REVERSEREAD | samtools view -b > ${SCRATCHNODE}/${SAMPLE_NAME}.aln-pe.bam"
printf "\n%s\n\n" "$CMD"
eval $CMD

# align merged reads and convert to bam
CMD="bwa-mem2 mem -t $CPUS -R '$readgroup' $REFERENCE $MERGEDREAD | samtools view -b > ${SCRATCHNODE}/${SAMPLE_NAME}.aln-se.bam"
printf "\n%s\n\n" "$CMD"
eval $CMD

# process bam files 

# paired end, sort by name, filter proper pairs, fixmate
samtools sort -n -@ $CPUS ${SCRATCHNODE}/${SAMPLE_NAME}.aln-pe.bam \
    | samtools view -f 0x2 -b \
    | samtools fixmate -m - ${SCRATCHNODE}/${SAMPLE_NAME}.fixmate-pe.bam
echo "PE fixmate BAM saved as ${SCRATCHNODE}/${SAMPLE_NAME}.fixmate-pe.bam"

# single end, filter unmapped 
samtools view -F 0x4 -b ${SCRATCHNODE}/${SAMPLE_NAME}.aln-se.bam \
    > ${SCRATCHNODE}/${SAMPLE_NAME}.filt-se.bam
echo "Filtered SE BAM saved as ${SCRATCHNODE}/${SAMPLE_NAME}.filt-se.bam"

# merge paired and single end bam files, position-sort and markdups
samtools merge -f ${SCRATCHNODE}/${SAMPLE_NAME}.merged.bam \
    ${SCRATCHNODE}/${SAMPLE_NAME}.fixmate-pe.bam \
    ${SCRATCHNODE}/${SAMPLE_NAME}.filt-se.bam

samtools sort -@ $CPUS -o ${SCRATCHNODE}/${SAMPLE_NAME}.positionsort.bam \
    ${SCRATCHNODE}/${SAMPLE_NAME}.merged.bam

samtools markdup -r -@ $CPUS \
    ${SCRATCHNODE}/${SAMPLE_NAME}.positionsort.bam \
    ${OUTDIR}/${SAMPLE_NAME}.rmdup.bam

wait

echo "Done! Final BAM is at ${OUTDIR}/${SAMPLE_NAME}.rmdup.bam"

## END SCRIPT
 

